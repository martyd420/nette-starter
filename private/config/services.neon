services:
	- App\Core\RouterFactory::createRouter

	# Services needing explicit arguments; everything else is registered by search below.
	- App\Model\Factory\MailerFactory(%mailer%)


search:
	- in: %appDir%
		classes:
			- *Facade
			- *Factory
			- *Repository
			- *Service
			- *Mailer
			- *Logger
			- *Fixture
